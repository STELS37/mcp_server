# MCP Server Configuration
# Copy this to .env and fill in your values

# Base URL of the MCP server (public HTTPS URL)
MCP_BASE_URL=https://mcp.yourdomain.com

# Environment
MCP_ENVIRONMENT=production
MCP_DEBUG=false

# Server Settings
MCP_SERVER__HOST=0.0.0.0
MCP_SERVER__PORT=8000
MCP_SERVER__LOG_LEVEL=info

# SSH Target Configuration (Experimental VPS)
MCP_SSH__HOST=your-experimental-vps-ip
MCP_SSH__PORT=22
MCP_SSH__USER=root
MCP_SSH__PRIVATE_KEY_PATH=/app/secrets/ssh_key
MCP_SSH__PRIVATE_KEY_PASSPHRASE=
MCP_SSH__CONNECTION_TIMEOUT=30
MCP_SSH__COMMAND_TIMEOUT=30

# OAuth/OIDC Configuration
# Choose your OAuth provider (Auth0, Keycloak, Google, etc.)

# Issuer URL (examples):
# Auth0: https://your-tenant.auth0.com/
# Keycloak: https://keycloak.yourdomain.com/realms/your-realm
# Google: https://accounts.google.com
MCP_OAUTH__ISSUER_URL=https://your-tenant.auth0.com/
MCP_OAUTH__AUTHORIZATION_ENDPOINT=https://your-tenant.auth0.com/authorize
MCP_OAUTH__TOKEN_ENDPOINT=https://your-tenant.auth0.com/oauth/token
MCP_OAUTH__USERINFO_ENDPOINT=https://your-tenant.auth0.com/userinfo
MCP_OAUTH__JWKS_URI=https://your-tenant.auth0.com/.well-known/jwks.json
MCP_OAUTH__CLIENT_ID=your-client-id
MCP_OAUTH__CLIENT_SECRET=your-client-secret
MCP_OAUTH__SCOPES=openid,profile,email,offline_access
MCP_OAUTH__AUDIENCE=https://mcp.yourdomain.com

# Redis (optional, for rate limiting)
MCP_REDIS_URL=redis://localhost:6379/0

# Logging
MCP_LOGGING__LEVEL=INFO
MCP_LOGGING__PATH=/var/log/mcp-server
MCP_LOGGING__LOG_TOOL_CALLS=true
